# WooCommerce connection
# 1. Your Woo REST base URL (no trailing slash)
VITE_WOO_URL=https://api.wonderlyf.co.uk

# 2. WooCommerce REST API keys
#    Generate at: WP Admin → WooCommerce → Settings → Advanced → REST API → Add key
#    Permissions: Read (Store API handles cart/checkout with its own session)
VITE_WOO_KEY=ck_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_WOO_SECRET=cs_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
